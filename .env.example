# Copy to .env for local dev. These are the Supabase project's public URL and
# anon key (safe to expose client-side by design) — never put a service-role
# key here or in any client-facing file.
#
# Production (Vercel dashboard, Production + Preview environments) must have
# these two set too, or the deployed build breaks (undefined Supabase client).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Maps Platform browser key — Places API + Places API (New) enabled.
# Restrict it in Cloud Console to HTTP referrers (solarsearch.com.au,
# solarsafe.au, localhost for dev) so it can't be used from other origins.
# Also needed on Vercel (Production + Preview) or address autofill silently
# no-ops (src/lib/places.js logs a console warning and skips it).
VITE_GOOGLE_MAPS_API_KEY=
